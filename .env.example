# ──────────────────────────────────────────────────────────────
# Apache Jena Fuseki
# Lokal  : biarkan default (jalankan setup-fuseki.bat)
# Produksi: arahkan ke host Fuseki eksternal (HTTPS), mis.
#           https://fuseki.contoh.com/webdev/sparql
# Hanya FUSEKI_ENDPOINT yang dipakai saat runtime (query SPARQL).
# FUSEKI_UPDATE/FUSEKI_DATA hanya untuk seeding/admin (opsional).
# ──────────────────────────────────────────────────────────────
FUSEKI_ENDPOINT=http://localhost:3030/webdev/sparql
FUSEKI_UPDATE=http://localhost:3030/webdev/update
FUSEKI_DATA=http://localhost:3030/webdev/data

# ──────────────────────────────────────────────────────────────
# NextAuth
# Produksi: NEXTAUTH_URL = domain publik aplikasi (https://...)
# Generate secret: openssl rand -base64 32
# ──────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-this-in-production

# ──────────────────────────────────────────────────────────────
# Google OAuth — https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: <NEXTAUTH_URL>/api/auth/callback/google
# ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
