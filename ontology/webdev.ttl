# ============================================================
# SEMANTIC WEB STANDARDS & GRAPH TOOLS
# ============================================================

ex:RDF a ex:SemanticWebSpec ;
  rdfs:label "RDF" ;
  ex:description "Resource Description Framework, the core data model of the Semantic Web based on subject-predicate-object triples." ;
  ex:website "https://www.w3.org/RDF/"^^xsd:anyURI .

ex:RDFS a ex:SemanticWebSpec ;
  rdfs:label "RDF Schema" ;
  ex:description "A semantic extension of RDF providing basic vocabulary for class and property hierarchies." ;
  ex:website "https://www.w3.org/TR/rdf-schema/"^^xsd:anyURI ;
  ex:isBuiltOn ex:RDF .

ex:OWL2 a ex:SemanticWebSpec ;
  rdfs:label "OWL 2" ;
  ex:description "Web Ontology Language for defining rich and machine-interpretable ontologies." ;
  ex:website "https://www.w3.org/TR/owl2-overview/"^^xsd:anyURI ;
  ex:isBuiltOn ex:RDFS .

ex:SPARQL a ex:SemanticWebSpec ;
  rdfs:label "SPARQL" ;
  ex:description "A query language and protocol for RDF graphs." ;
  ex:website "https://www.w3.org/TR/sparql11-query/"^^xsd:anyURI ;
  ex:isBuiltOn ex:RDF .

ex:TurtleSyntax a ex:SemanticWebSpec ;
  rdfs:label "Turtle" ;
  ex:description "A compact, human-readable syntax for RDF serialization, commonly used for ontology authoring." ;
  ex:website "https://www.w3.org/TR/turtle/"^^xsd:anyURI ;
  ex:isBuiltOn ex:RDF .

ex:JSONLD a ex:SemanticWebSpec ;
  rdfs:label "JSON-LD" ;
  ex:description "JSON-based serialization format for linked data and knowledge graphs." ;
  ex:website "https://json-ld.org"^^xsd:anyURI ;
  ex:isBuiltOn ex:RDF .

ex:SHACL a ex:SemanticWebSpec ;
  rdfs:label "SHACL" ;
  ex:description "Shapes Constraint Language for validating RDF graphs against structural constraints." ;
  ex:website "https://www.w3.org/TR/shacl/"^^xsd:anyURI ;
  ex:isBuiltOn ex:RDF .

ex:ApacheJena a ex:Library ;
  rdfs:label "Apache Jena" ;
  ex:description "A Java framework and toolkit for building Semantic Web and linked-data applications." ;
  ex:website "https://jena.apache.org"^^xsd:anyURI ;
  ex:implementsSpec ex:RDF ;
  ex:implementsSpec ex:RDFS ;
  ex:implementsSpec ex:OWL2 ;
  ex:implementsSpec ex:SPARQL ;
  ex:implementsSpec ex:TurtleSyntax .

ex:Fuseki a ex:Triplestore ;
  rdfs:label "Apache Jena Fuseki" ;
  ex:description "A SPARQL server providing RDF graph storage, query endpoints, and update operations over HTTP." ;
  ex:website "https://jena.apache.org/documentation/fuseki2/"^^xsd:anyURI ;
  ex:isBuiltOn ex:ApacheJena ;
  ex:implementsSpec ex:RDF ;
  ex:implementsSpec ex:SPARQL ;
  ex:implementsSpec ex:TurtleSyntax ;
  ex:compatibleWith ex:NextJS ;
  ex:compatibleWith ex:Axios ;
  ex:alternativeTo ex:GraphDB ;
  ex:alternativeTo ex:Blazegraph ;
  ex:alternativeTo ex:Virtuoso .

ex:GraphDB a ex:Triplestore ;
  rdfs:label "GraphDB" ;
  ex:description "A graph database and triplestore for RDF and SPARQL with reasoning support." ;
  ex:website "https://graphdb.ontotext.com"^^xsd:anyURI ;
  ex:implementsSpec ex:RDF ;
  ex:implementsSpec ex:SPARQL ;
  ex:alternativeTo ex:Fuseki .

ex:Blazegraph a ex:Triplestore ;
  rdfs:label "Blazegraph" ;
  ex:description "A high-performance graph database supporting RDF and SPARQL workloads." ;
  ex:website "https://blazegraph.com"^^xsd:anyURI ;
  ex:implementsSpec ex:RDF ;
  ex:implementsSpec ex:SPARQL ;
  ex:alternativeTo ex:Fuseki .

ex:Virtuoso a ex:Triplestore ;
  rdfs:label "OpenLink Virtuoso" ;
  ex:description "A multi-model database with strong support for RDF data management and SPARQL querying." ;
  ex:website "https://virtuoso.openlinksw.com"^^xsd:anyURI ;
  ex:implementsSpec ex:RDF ;
  ex:implementsSpec ex:SPARQL ;
  ex:alternativeTo ex:Fuseki .

ex:Comunica a ex:Library ;
  rdfs:label "Comunica" ;
  ex:description "A modular SPARQL query engine for JavaScript that can query local and remote linked data sources." ;
  ex:website "https://comunica.dev"^^xsd:anyURI ;
  ex:usesLanguage ex:JavaScript ;
  ex:compatibleWith ex:NodeJS ;
  ex:compatibleWith ex:SPARQL ;
  ex:connectsTo ex:Fuseki .

ex:N3JS a ex:Library ;
  rdfs:label "N3.js" ;
  ex:description "An RDF library for JavaScript to parse, serialize, and manipulate triples/quads." ;
  ex:website "https://github.com/rdfjs/N3.js"^^xsd:anyURI ;
  ex:usesLanguage ex:JavaScript ;
  ex:implementsSpec ex:RDF ;
  ex:implementsSpec ex:TurtleSyntax ;
  ex:compatibleWith ex:NodeJS .

ex:RDFJS a ex:Library ;
  rdfs:label "RDF/JS" ;
  ex:description "A JavaScript specification and ecosystem for interoperable RDF data interfaces." ;
  ex:website "https://rdf.js.org"^^xsd:anyURI ;
  ex:usesLanguage ex:JavaScript ;
  ex:implementsSpec ex:RDF ;
  ex:compatibleWith ex:N3JS ;
  ex:compatibleWith ex:Comunica .

