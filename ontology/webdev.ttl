# ============================================================
# NEW CLASSES (v3.0)
# ============================================================

ex:CloudProvider a rdfs:Class ;
  rdfs:subClassOf ex:Technology ;
  rdfs:label "Cloud Provider" ;
  rdfs:comment "A cloud computing platform offering hosting, compute, and managed services." .

ex:CITool a rdfs:Class ;
  rdfs:subClassOf ex:Technology ;
  rdfs:label "CI/CD Tool" ;
  rdfs:comment "A tool for continuous integration and continuous deployment pipelines." .

ex:VersionControl a rdfs:Class ;
  rdfs:subClassOf ex:Technology ;
  rdfs:label "Version Control" ;
  rdfs:comment "A system for tracking changes to source code over time." .

ex:ContainerTool a rdfs:Class ;
  rdfs:subClassOf ex:Technology ;
  rdfs:label "Container Tool" ;
  rdfs:comment "A tool for containerizing, orchestrating, or managing application containers." .

ex:MonitoringTool a rdfs:Class ;
  rdfs:subClassOf ex:Technology ;
  rdfs:label "Monitoring Tool" ;
  rdfs:comment "A tool for application observability, error tracking, and performance monitoring." .

ex:MessageBroker a rdfs:Class ;
  rdfs:subClassOf ex:Technology ;
  rdfs:label "Message Broker" ;
  rdfs:comment "A middleware system for asynchronous message passing between services." .

ex:SearchTool a rdfs:Class ;
  rdfs:subClassOf ex:Library ;
  rdfs:label "Search Engine" ;
  rdfs:comment "A tool or service for full-text search and discovery in applications." .

ex:StorageService a rdfs:Class ;
  rdfs:subClassOf ex:Technology ;
  rdfs:label "Storage Service" ;
  rdfs:comment "A service for storing and serving files, blobs, or objects in the cloud." .

ex:ValidationLib a rdfs:Class ;
  rdfs:subClassOf ex:Library ;
  rdfs:label "Validation Library" ;
  rdfs:comment "A library for validating and parsing structured data against schemas." .

ex:DesignTool a rdfs:Class ;
  rdfs:subClassOf ex:Technology ;
  rdfs:label "Design Tool" ;
  rdfs:comment "A tool used for UI/UX design, prototyping, and design collaboration." .

ex:MobileFramework a rdfs:Class ;
  rdfs:subClassOf ex:Framework ;
  rdfs:label "Mobile Framework" ;
  rdfs:comment "A framework for building mobile or cross-platform applications." .

ex:DesktopFramework a rdfs:Class ;
  rdfs:subClassOf ex:Framework ;
  rdfs:label "Desktop Framework" ;
  rdfs:comment "A framework for building cross-platform desktop apps using web technologies." .

# ============================================================
# NEW OBJECT PROPERTIES (v3.0)
# ============================================================

ex:hostedBy a rdf:Property ;
  rdfs:label "hostedBy" ;
  rdfs:domain ex:Technology ;
  rdfs:range ex:CloudProvider .

ex:monitoredBy a rdf:Property ;
  rdfs:label "monitoredBy" ;
  rdfs:domain ex:Technology ;
  rdfs:range ex:MonitoringTool .

ex:ciWith a rdf:Property ;
  rdfs:label "ciWith" ;
  rdfs:domain ex:Technology ;
  rdfs:range ex:CITool .

ex:usesBroker a rdf:Property ;
  rdfs:label "usesBroker" ;
  rdfs:domain ex:Technology ;
  rdfs:range ex:MessageBroker .

ex:searchedWith a rdf:Property ;
  rdfs:label "searchedWith" ;
  rdfs:domain ex:Technology ;
  rdfs:range ex:SearchTool .

ex:storedWith a rdf:Property ;
  rdfs:label "storedWith" ;
  rdfs:domain ex:Technology ;
  rdfs:range ex:StorageService .

ex:designedWith a rdf:Property ;
  rdfs:label "designedWith" ;
  rdfs:domain ex:Technology ;
  rdfs:range ex:DesignTool .

ex:versionControlledBy a rdf:Property ;
  rdfs:label "versionControlledBy" ;
  rdfs:domain ex:Technology ;
  rdfs:range ex:VersionControl .

