@prefix ex:    <http://webdev.id/ontology#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .

# ============================================================
# ONTOLOGY DECLARATION
# ============================================================
<http://webdev.id/ontology>
  a owl:Ontology ;
  rdfs:label "Web Development Technology Ontology" ;
  rdfs:comment "Comprehensive semantic directory of web development technologies — frameworks, libraries, ORMs, databases, runtimes, languages, build tools, testing tools, state management, CSS frameworks, authentication, deployment, and more." ;
  owl:versionInfo "2.0" .

# ============================================================
# CLASSES
# ============================================================

ex:Technology a rdfs:Class ;
  rdfs:label "Technology" ;
  rdfs:comment "A generic web development technology." .

ex:Framework a rdfs:Class ;
  rdfs:subClassOf ex:Technology ;
  rdfs:label "Framework" ;
  rdfs:comment "A full-featured web application framework." .

ex:Library a rdfs:Class ;
  rdfs:subClassOf ex:Technology ;
  rdfs:label "Library" ;
  rdfs:comment "A reusable code library." .

ex:ORM a rdfs:Class ;
  rdfs:subClassOf ex:Technology ;
  rdfs:label "ORM" ;
  rdfs:comment "Object-Relational Mapping or query-builder tool." .

ex:Database a rdfs:Class ;
  rdfs:subClassOf ex:Technology ;
  rdfs:label "Database" ;
  rdfs:comment "A database management system." .

ex:Language a rdfs:Class ;
  rdfs:subClassOf ex:Technology ;
  rdfs:label "Language" ;
  rdfs:comment "A programming or scripting language." .

ex:Runtime a rdfs:Class ;
  rdfs:subClassOf ex:Technology ;
  rdfs:label "Runtime" ;
  rdfs:comment "A JavaScript runtime environment." .

ex:CSSFramework a rdfs:Class ;
  rdfs:subClassOf ex:Library ;
  rdfs:label "CSS Framework" ;
  rdfs:comment "A CSS utility, component, or styling framework." .

ex:BuildTool a rdfs:Class ;
  rdfs:subClassOf ex:Technology ;
  rdfs:label "Build Tool" ;
  rdfs:comment "A tool for bundling, compiling, or building web projects." .

ex:TestingTool a rdfs:Class ;
  rdfs:subClassOf ex:Technology ;
  rdfs:label "Testing Tool" ;
  rdfs:comment "A framework or library for testing code." .

ex:StateManagement a rdfs:Class ;
  rdfs:subClassOf ex:Library ;
  rdfs:label "State Management" ;
  rdfs:comment "A library for managing application state." .

ex:AuthTool a rdfs:Class ;
  rdfs:subClassOf ex:Library ;
  rdfs:label "Auth Tool" ;
  rdfs:comment "A library or service for authentication and authorization." .

ex:DeploymentTool a rdfs:Class ;
  rdfs:subClassOf ex:Technology ;
  rdfs:label "Deployment Tool" ;
  rdfs:comment "A platform or tool for deploying web applications." .

ex:APITool a rdfs:Class ;
  rdfs:subClassOf ex:Technology ;
  rdfs:label "API Tool" ;
  rdfs:comment "A tool or specification for building APIs (REST, GraphQL, tRPC, etc)." .

ex:Linter a rdfs:Class ;
  rdfs:subClassOf ex:Technology ;
  rdfs:label "Linter / Formatter" ;
  rdfs:comment "A tool for linting or formatting code." .

ex:UIComponentLib a rdfs:Class ;
  rdfs:subClassOf ex:Library ;
  rdfs:label "UI Component Library" ;
  rdfs:comment "A pre-built component library for UI development." .

ex:Monorepo a rdfs:Class ;
  rdfs:subClassOf ex:BuildTool ;
  rdfs:label "Monorepo Tool" ;
  rdfs:comment "A tool for managing monorepo projects." .

ex:PackageManager a rdfs:Class ;
  rdfs:subClassOf ex:Technology ;
  rdfs:label "Package Manager" ;
  rdfs:comment "A tool for managing project dependencies." .

ex:Animation a rdfs:Class ;
  rdfs:subClassOf ex:Library ;
  rdfs:label "Animation Library" ;
  rdfs:comment "A library for UI animations and transitions." .

# ============================================================
# OBJECT PROPERTIES
# ============================================================

ex:isFrameworkOf a rdf:Property ;
  rdfs:label "isFrameworkOf" ;
  rdfs:domain ex:Framework ;
  rdfs:range ex:Library .

ex:isBuiltOn a rdf:Property ;
  rdfs:label "isBuiltOn" ;
  rdfs:domain ex:Technology ;
  rdfs:range ex:Technology .

ex:isORMFor a rdf:Property ;
  rdfs:label "isORMFor" ;
  rdfs:domain ex:ORM ;
  rdfs:range ex:Database .

ex:usesLanguage a rdf:Property ;
  rdfs:label "usesLanguage" ;
  rdfs:domain ex:Technology ;
  rdfs:range ex:Language .

ex:alternativeTo a rdf:Property ;
  rdfs:label "alternativeTo" ;
  rdfs:domain ex:Technology ;
  rdfs:range ex:Technology .

ex:compatibleWith a rdf:Property ;
  rdfs:label "compatibleWith" ;
  rdfs:domain ex:Technology ;
  rdfs:range ex:Technology .

ex:connectsTo a rdf:Property ;
  rdfs:label "connectsTo" ;
  rdfs:domain ex:Technology ;
  rdfs:range ex:Technology .

ex:integratesWith a rdf:Property ;
  rdfs:label "integratesWith" ;
  rdfs:domain ex:Technology ;
  rdfs:range ex:Technology .

ex:testedWith a rdf:Property ;
  rdfs:label "testedWith" ;
  rdfs:domain ex:Technology ;
  rdfs:range ex:TestingTool .

ex:deployedOn a rdf:Property ;
  rdfs:label "deployedOn" ;
  rdfs:domain ex:Framework ;
  rdfs:range ex:DeploymentTool .

ex:managedBy a rdf:Property ;
  rdfs:label "managedBy" ;
  rdfs:domain ex:Technology ;
  rdfs:range ex:PackageManager .

# DATA PROPERTIES
ex:description a rdf:Property ;
  rdfs:label "description" ;
  rdfs:range xsd:string .

ex:website a rdf:Property ;
  rdfs:label "website" ;
  rdfs:range xsd:anyURI .

ex:version a rdf:Property ;
  rdfs:label "version" ;
  rdfs:range xsd:string .

ex:githubStars a rdf:Property ;
  rdfs:label "githubStars" ;
  rdfs:range xsd:string .

ex:license a rdf:Property ;
  rdfs:label "license" ;
  rdfs:range xsd:string .

ex:firstRelease a rdf:Property ;
  rdfs:label "firstRelease" ;
  rdfs:range xsd:string .

ex:creator a rdf:Property ;
  rdfs:label "creator" ;
  rdfs:range xsd:string .

# ============================================================
# LANGUAGES
# ============================================================

ex:JavaScript a ex:Language ;
  rdfs:label "JavaScript" ;
  ex:description "The language of the web. Runs in browsers and on servers via Node.js." ;
  ex:website "https://developer.mozilla.org/en-US/docs/Web/JavaScript"^^xsd:anyURI ;
  ex:firstRelease "1995" ;
  ex:creator "Brendan Eich" .

ex:TypeScript a ex:Language ;
  rdfs:label "TypeScript" ;
  ex:description "A strongly typed superset of JavaScript that compiles to plain JS. Developed by Microsoft." ;
  ex:website "https://www.typescriptlang.org"^^xsd:anyURI ;
  ex:isBuiltOn ex:JavaScript ;
  ex:version "5.4" ;
  ex:firstRelease "2012" ;
  ex:creator "Microsoft" ;
  ex:githubStars "~100k" .

ex:PHP a ex:Language ;
  rdfs:label "PHP" ;
  ex:description "A widely-used server-side scripting language designed for web development." ;
  ex:website "https://www.php.net"^^xsd:anyURI ;
  ex:version "8.3" ;
  ex:firstRelease "1994" .

ex:Python a ex:Language ;
  rdfs:label "Python" ;
  ex:description "A general-purpose, high-level language known for readability and simplicity." ;
  ex:website "https://www.python.org"^^xsd:anyURI ;
  ex:version "3.12" ;
  ex:firstRelease "1991" .

ex:Rust a ex:Language ;
  rdfs:label "Rust" ;
  ex:description "A systems language focused on safety, speed, and concurrency. Used in tooling (Vite, SWC)." ;
  ex:website "https://www.rust-lang.org"^^xsd:anyURI ;
  ex:version "1.78" ;
  ex:firstRelease "2010" .

ex:Go a ex:Language ;
  rdfs:label "Go" ;
  ex:description "A statically typed, compiled language by Google. Popular for backend microservices." ;
  ex:website "https://go.dev"^^xsd:anyURI ;
  ex:version "1.22" ;
  ex:firstRelease "2009" ;
  ex:creator "Google" .

ex:Ruby a ex:Language ;
  rdfs:label "Ruby" ;
  ex:description "A dynamic, open-source language focused on simplicity and developer happiness." ;
  ex:website "https://www.ruby-lang.org"^^xsd:anyURI ;
  ex:version "3.3" ;
  ex:firstRelease "1995" .

ex:Kotlin a ex:Language ;
  rdfs:label "Kotlin" ;
  ex:description "A modern statically typed language running on JVM. Used in Android and backend (Ktor)." ;
  ex:website "https://kotlinlang.org"^^xsd:anyURI ;
  ex:firstRelease "2011" ;
  ex:creator "JetBrains" .

ex:Dart a ex:Language ;
  rdfs:label "Dart" ;
  ex:description "A client-optimized language by Google, primary language of Flutter." ;
  ex:website "https://dart.dev"^^xsd:anyURI ;
  ex:creator "Google" .

# ============================================================
# RUNTIMES & PACKAGE MANAGERS
# ============================================================

ex:NodeJS a ex:Runtime ;
  rdfs:label "Node.js" ;
  ex:description "A JavaScript runtime built on Chrome V8 engine enabling server-side JavaScript." ;
  ex:website "https://nodejs.org"^^xsd:anyURI ;
  ex:usesLanguage ex:JavaScript ;
  ex:version "20 LTS" ;
  ex:githubStars "~104k" ;
  ex:firstRelease "2009" ;
  ex:creator "Ryan Dahl" .

ex:Bun a ex:Runtime ;
  rdfs:label "Bun" ;
  ex:description "An all-in-one JavaScript runtime, bundler, test runner and package manager. Built with Zig." ;
  ex:website "https://bun.sh"^^xsd:anyURI ;
  ex:usesLanguage ex:JavaScript ;
  ex:alternativeTo ex:NodeJS ;
  ex:version "1.1" ;
  ex:githubStars "~72k" .

ex:Deno a ex:Runtime ;
  rdfs:label "Deno" ;
  ex:description "A secure JavaScript/TypeScript runtime by the creator of Node.js. Built on V8 and Rust." ;
  ex:website "https://deno.com"^^xsd:anyURI ;
  ex:usesLanguage ex:TypeScript ;
  ex:alternativeTo ex:NodeJS ;
  ex:version "1.44" ;
  ex:githubStars "~93k" ;
  ex:creator "Ryan Dahl" .

ex:npm a ex:PackageManager ;
  rdfs:label "npm" ;
  ex:description "The default package manager for Node.js and the world's largest software registry." ;
  ex:website "https://www.npmjs.com"^^xsd:anyURI ;
  ex:isBuiltOn ex:NodeJS .

ex:Yarn a ex:PackageManager ;
  rdfs:label "Yarn" ;
  ex:description "A fast, reliable, and secure dependency management tool for JavaScript." ;
  ex:website "https://yarnpkg.com"^^xsd:anyURI ;
  ex:alternativeTo ex:npm .

ex:Pnpm a ex:PackageManager ;
  rdfs:label "pnpm" ;
  ex:description "A fast, disk-space-efficient package manager using a content-addressable store." ;
  ex:website "https://pnpm.io"^^xsd:anyURI ;
  ex:alternativeTo ex:npm ;
  ex:githubStars "~29k" .

# ============================================================
# DATABASES
# ============================================================

ex:PostgreSQL a ex:Database ;
  rdfs:label "PostgreSQL" ;
  ex:description "A powerful, open-source object-relational database with strong ACID compliance and advanced features." ;
  ex:website "https://www.postgresql.org"^^xsd:anyURI ;
  ex:version "16" ;
  ex:license "PostgreSQL License" ;
  ex:firstRelease "1996" .

ex:MySQL a ex:Database ;
  rdfs:label "MySQL" ;
  ex:description "The world's most popular open-source relational database, now owned by Oracle." ;
  ex:website "https://www.mysql.com"^^xsd:anyURI ;
  ex:alternativeTo ex:PostgreSQL ;
  ex:version "8.3" .

ex:MongoDB a ex:Database ;
  rdfs:label "MongoDB" ;
  ex:description "A document-oriented NoSQL database for flexible, JSON-like BSON storage." ;
  ex:website "https://www.mongodb.com"^^xsd:anyURI ;
  ex:version "7.0" ;
  ex:githubStars "~26k" .

ex:SQLite a ex:Database ;
  rdfs:label "SQLite" ;
  ex:description "A lightweight, serverless, self-contained SQL database engine embedded in applications." ;
  ex:website "https://www.sqlite.org"^^xsd:anyURI ;
  ex:license "Public Domain" .

ex:Redis a ex:Database ;
  rdfs:label "Redis" ;
  ex:description "An in-memory data structure store used as database, cache, and message broker." ;
  ex:website "https://redis.io"^^xsd:anyURI ;
  ex:githubStars "~65k" ;
  ex:version "7.2" .

ex:MariaDB a ex:Database ;
  rdfs:label "MariaDB" ;
  ex:description "A community-developed fork of MySQL with performance improvements and new features." ;
  ex:website "https://mariadb.org"^^xsd:anyURI ;
  ex:alternativeTo ex:MySQL ;
  ex:isBuiltOn ex:MySQL .

ex:CockroachDB a ex:Database ;
  rdfs:label "CockroachDB" ;
  ex:description "A distributed SQL database designed for cloud environments with horizontal scalability." ;
  ex:website "https://www.cockroachlabs.com"^^xsd:anyURI ;
  ex:alternativeTo ex:PostgreSQL ;
  ex:compatibleWith ex:PostgreSQL .

ex:Neon a ex:Database ;
  rdfs:label "Neon" ;
  ex:description "A serverless PostgreSQL platform with autoscaling, branching, and bottomless storage." ;
  ex:website "https://neon.tech"^^xsd:anyURI ;
  ex:isBuiltOn ex:PostgreSQL ;
  ex:compatibleWith ex:Prisma ;
  ex:compatibleWith ex:Drizzle .

ex:Turso a ex:Database ;
  rdfs:label "Turso" ;
  ex:description "An edge-hosted distributed SQLite database built on libSQL for low-latency global access." ;
  ex:website "https://turso.tech"^^xsd:anyURI ;
  ex:isBuiltOn ex:SQLite ;
  ex:compatibleWith ex:Drizzle .

ex:PlanetScale a ex:Database ;
  rdfs:label "PlanetScale" ;
  ex:description "A serverless MySQL-compatible database platform with branching workflows for schema changes." ;
  ex:website "https://planetscale.com"^^xsd:anyURI ;
  ex:isBuiltOn ex:MySQL ;
  ex:compatibleWith ex:Prisma .

ex:Supabase a ex:Database ;
  rdfs:label "Supabase" ;
  ex:description "An open-source Firebase alternative built on PostgreSQL. Provides auth, storage, and realtime." ;
  ex:website "https://supabase.com"^^xsd:anyURI ;
  ex:isBuiltOn ex:PostgreSQL ;
  ex:compatibleWith ex:Prisma ;
  ex:githubStars "~71k" .

ex:Firebase a ex:Database ;
  rdfs:label "Firebase" ;
  ex:description "Google's app platform offering realtime NoSQL database, auth, hosting, and cloud functions." ;
  ex:website "https://firebase.google.com"^^xsd:anyURI ;
  ex:creator "Google" ;
  ex:alternativeTo ex:Supabase .

ex:DynamoDB a ex:Database ;
  rdfs:label "DynamoDB" ;
  ex:description "Amazon's fully managed NoSQL key-value and document database with single-digit ms latency." ;
  ex:website "https://aws.amazon.com/dynamodb"^^xsd:anyURI ;
  ex:creator "Amazon" ;
  ex:alternativeTo ex:MongoDB .

ex:Cassandra a ex:Database ;
  rdfs:label "Cassandra" ;
  ex:description "A highly scalable distributed NoSQL database designed for handling large amounts of data." ;
  ex:website "https://cassandra.apache.org"^^xsd:anyURI ;
  ex:creator "Apache" ;
  ex:alternativeTo ex:MongoDB .

ex:ElasticSearch a ex:Database ;
  rdfs:label "Elasticsearch" ;
  ex:description "A distributed, RESTful search and analytics engine built on Apache Lucene." ;
  ex:website "https://www.elastic.co"^^xsd:anyURI ;
  ex:githubStars "~69k" .

ex:Upstash a ex:Database ;
  rdfs:label "Upstash" ;
  ex:description "A serverless Redis and Kafka platform optimized for edge and serverless environments." ;
  ex:website "https://upstash.com"^^xsd:anyURI ;
  ex:isBuiltOn ex:Redis .

ex:Convex a ex:Database ;
  rdfs:label "Convex" ;
  ex:description "A reactive backend-as-a-service with a built-in database and real-time sync." ;
  ex:website "https://www.convex.dev"^^xsd:anyURI ;
  ex:compatibleWith ex:NextJS ;
  ex:compatibleWith ex:React .

ex:Xata a ex:Database ;
  rdfs:label "Xata" ;
  ex:description "A serverless database platform combining relational data, full-text search, and analytics." ;
  ex:website "https://xata.io"^^xsd:anyURI ;
  ex:isBuiltOn ex:PostgreSQL .

# ============================================================
# ORMs & QUERY BUILDERS
# ============================================================

ex:Prisma a ex:ORM ;
  rdfs:label "Prisma" ;
  ex:description "Next-generation Node.js and TypeScript ORM with a declarative schema and type-safe client." ;
  ex:website "https://www.prisma.io"^^xsd:anyURI ;
  ex:isORMFor ex:PostgreSQL ;
  ex:isORMFor ex:MySQL ;
  ex:isORMFor ex:SQLite ;
  ex:isORMFor ex:MongoDB ;
  ex:isORMFor ex:CockroachDB ;
  ex:isORMFor ex:Neon ;
  ex:usesLanguage ex:TypeScript ;
  ex:compatibleWith ex:NextJS ;
  ex:compatibleWith ex:NuxtJS ;
  ex:compatibleWith ex:Remix ;
  ex:version "5.14" ;
  ex:githubStars "~39k" .

ex:Drizzle a ex:ORM ;
  rdfs:label "Drizzle ORM" ;
  ex:description "A lightweight TypeScript ORM with SQL-like syntax. Zero dependencies, edge-compatible." ;
  ex:website "https://orm.drizzle.team"^^xsd:anyURI ;
  ex:isORMFor ex:PostgreSQL ;
  ex:isORMFor ex:MySQL ;
  ex:isORMFor ex:SQLite ;
  ex:isORMFor ex:Turso ;
  ex:isORMFor ex:Neon ;
  ex:usesLanguage ex:TypeScript ;
  ex:compatibleWith ex:NextJS ;
  ex:alternativeTo ex:Prisma ;
  ex:version "0.31" ;
  ex:githubStars "~23k" .

ex:TypeORM a ex:ORM ;
  rdfs:label "TypeORM" ;
  ex:description "An ORM for TypeScript and JavaScript supporting Active Record and Data Mapper patterns." ;
  ex:website "https://typeorm.io"^^xsd:anyURI ;
  ex:isORMFor ex:PostgreSQL ;
  ex:isORMFor ex:MySQL ;
  ex:isORMFor ex:SQLite ;
  ex:isORMFor ex:MongoDB ;
  ex:usesLanguage ex:TypeScript ;
  ex:alternativeTo ex:Prisma ;
  ex:githubStars "~33k" .

ex:Sequelize a ex:ORM ;
  rdfs:label "Sequelize" ;
  ex:description "A promise-based Node.js ORM for SQL databases with model validation and migrations." ;
  ex:website "https://sequelize.org"^^xsd:anyURI ;
  ex:isORMFor ex:PostgreSQL ;
  ex:isORMFor ex:MySQL ;
  ex:isORMFor ex:SQLite ;
  ex:isORMFor ex:MariaDB ;
  ex:usesLanguage ex:JavaScript ;
  ex:alternativeTo ex:Prisma ;
  ex:version "6" ;
  ex:githubStars "~29k" .

ex:MikroORM a ex:ORM ;
  rdfs:label "MikroORM" ;
  ex:description "A TypeScript ORM based on Data Mapper, Unit of Work, and Identity Map patterns." ;
  ex:website "https://mikro-orm.io"^^xsd:anyURI ;
  ex:isORMFor ex:PostgreSQL ;
  ex:isORMFor ex:MySQL ;
  ex:isORMFor ex:SQLite ;
  ex:isORMFor ex:MongoDB ;
  ex:usesLanguage ex:TypeScript ;
  ex:alternativeTo ex:Prisma ;
  ex:githubStars "~7k" .

ex:Mongoose a ex:ORM ;
  rdfs:label "Mongoose" ;
  ex:description "An elegant MongoDB object modeling library for Node.js with schema-based solution." ;
  ex:website "https://mongoosejs.com"^^xsd:anyURI ;
  ex:isORMFor ex:MongoDB ;
  ex:usesLanguage ex:JavaScript ;
  ex:githubStars "~26k" .

ex:Kysely a ex:ORM ;
  rdfs:label "Kysely" ;
  ex:description "A type-safe TypeScript SQL query builder with zero runtime overhead." ;
  ex:website "https://kysely.dev"^^xsd:anyURI ;
  ex:isORMFor ex:PostgreSQL ;
  ex:isORMFor ex:MySQL ;
  ex:isORMFor ex:SQLite ;
  ex:usesLanguage ex:TypeScript ;
  ex:alternativeTo ex:Drizzle ;
  ex:githubStars "~10k" .

ex:Knex a ex:ORM ;
  rdfs:label "Knex.js" ;
  ex:description "A flexible SQL query builder for Node.js supporting multiple databases." ;
  ex:website "https://knexjs.org"^^xsd:anyURI ;
  ex:isORMFor ex:PostgreSQL ;
  ex:isORMFor ex:MySQL ;
  ex:isORMFor ex:SQLite ;
  ex:usesLanguage ex:JavaScript ;
  ex:alternativeTo ex:Drizzle ;
  ex:githubStars "~19k" .

ex:Mongoose a ex:ORM ;
  rdfs:label "Mongoose" ;
  ex:description "An elegant MongoDB object modeling for Node.js with schema validation." ;
  ex:website "https://mongoosejs.com"^^xsd:anyURI ;
  ex:isORMFor ex:MongoDB ;
  ex:usesLanguage ex:JavaScript .

# ============================================================
# FRONTEND LIBRARIES
# ============================================================

ex:React a ex:Library ;
  rdfs:label "React" ;
  ex:description "A declarative, component-based JavaScript library for building user interfaces. Maintained by Meta." ;
  ex:website "https://react.dev"^^xsd:anyURI ;
  ex:usesLanguage ex:JavaScript ;
  ex:usesLanguage ex:TypeScript ;
  ex:version "18" ;
  ex:githubStars "~225k" ;
  ex:creator "Meta" ;
  ex:firstRelease "2013" .

ex:Vue a ex:Library ;
  rdfs:label "Vue.js" ;
  ex:description "A progressive JavaScript framework for building user interfaces with a gentle learning curve." ;
  ex:website "https://vuejs.org"^^xsd:anyURI ;
  ex:usesLanguage ex:JavaScript ;
  ex:alternativeTo ex:React ;
  ex:version "3.4" ;
  ex:githubStars "~207k" ;
  ex:firstRelease "2014" .

ex:Svelte a ex:Library ;
  rdfs:label "Svelte" ;
  ex:description "A compiler-based frontend framework that ships no virtual DOM or runtime to the browser." ;
  ex:website "https://svelte.dev"^^xsd:anyURI ;
  ex:usesLanguage ex:JavaScript ;
  ex:alternativeTo ex:React ;
  ex:version "4" ;
  ex:githubStars "~77k" .

ex:Solid a ex:Library ;
  rdfs:label "SolidJS" ;
  ex:description "A declarative, efficient, and flexible JavaScript library with fine-grained reactivity." ;
  ex:website "https://www.solidjs.com"^^xsd:anyURI ;
  ex:usesLanguage ex:JavaScript ;
  ex:alternativeTo ex:React ;
  ex:githubStars "~31k" .

ex:Preact a ex:Library ;
  rdfs:label "Preact" ;
  ex:description "A fast 3kB alternative to React with the same modern API. Minimal footprint." ;
  ex:website "https://preactjs.com"^^xsd:anyURI ;
  ex:usesLanguage ex:JavaScript ;
  ex:alternativeTo ex:React ;
  ex:githubStars "~36k" .

ex:Angular a ex:Framework ;
  rdfs:label "Angular" ;
  ex:description "A platform and framework for building single-page client applications using TypeScript. By Google." ;
  ex:website "https://angular.dev"^^xsd:anyURI ;
  ex:usesLanguage ex:TypeScript ;
  ex:alternativeTo ex:React ;
  ex:version "17" ;
  ex:githubStars "~95k" ;
  ex:creator "Google" .

ex:Lit a ex:Library ;
  rdfs:label "Lit" ;
  ex:description "A simple library by Google for building fast, lightweight web components with minimal boilerplate." ;
  ex:website "https://lit.dev"^^xsd:anyURI ;
  ex:usesLanguage ex:TypeScript ;
  ex:creator "Google" ;
  ex:githubStars "~17k" .

ex:Alpine a ex:Library ;
  rdfs:label "Alpine.js" ;
  ex:description "A rugged, minimal JavaScript framework for composing behavior directly in HTML markup." ;
  ex:website "https://alpinejs.dev"^^xsd:anyURI ;
  ex:usesLanguage ex:JavaScript ;
  ex:alternativeTo ex:Vue ;
  ex:githubStars "~27k" .

ex:HTMX a ex:Library ;
  rdfs:label "HTMX" ;
  ex:description "A library that allows HTML to make AJAX, CSS transitions, WebSockets, and Server-Sent Events." ;
  ex:website "https://htmx.org"^^xsd:anyURI ;
  ex:usesLanguage ex:JavaScript ;
  ex:githubStars "~37k" .

ex:Qwik a ex:Framework ;
  rdfs:label "Qwik" ;
  ex:description "A resumable JavaScript framework designed for instant loading with O(1) initial JS." ;
  ex:website "https://qwik.dev"^^xsd:anyURI ;
  ex:usesLanguage ex:TypeScript ;
  ex:alternativeTo ex:React ;
  ex:githubStars "~20k" .

# ============================================================
# FULL-STACK FRAMEWORKS
# ============================================================

ex:NextJS a ex:Framework ;
  rdfs:label "Next.js" ;
  ex:description "The React framework for production. Supports SSR, SSG, ISR, API routes, and App Router." ;
  ex:website "https://nextjs.org"^^xsd:anyURI ;
  ex:isFrameworkOf ex:React ;
